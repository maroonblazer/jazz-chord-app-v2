{
  "name": "jazz-chord-app-v2",
  "version": "1.0.0",
  "description": "My package file",
  "main": "app.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "start:refactored": "node server-refactored.js",
    "create-sprite": "svg-sprite --symbol --symbol-dest=out --symbol-sprite=icons.svg --symbol-example=true public/svgs/*.svg",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "NODE_OPTIONS='--experimental-global-webcrypto --experimental-global-customevent' jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:component": "jest tests/component",
    "test:performance": "jest tests/performance --runInBand",
    "test:accessibility": "jest tests/accessibility --runInBand",
    "test:e2e": "npx playwright test",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:component && npm run test:e2e",
    "test:fast": "npm run test:unit && npm run test:integration && npm run test:component"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maroonblazer/jazz-chord-app-v2.git"
  },
  "author": "Nick Ketter",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/maroonblazer/jazz-chord-app-v2/issues"
  },
  "homepage": "https://github.com/maroonblazer/jazz-chord-app-v2#readme",
  "dependencies": {
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "d3-dsv": "^2.0.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "langchain": "^0.1.0",
    "openai": "^4.24.1",
    "pdf-parse": "^1.1.1",
    "puppeteer": "^19.11.1",
    "request": "^2.88.2",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "svg-sprite": "^2.0.2",
    "youtube-transcript": "^1.0.6",
    "youtubei.js": "^5.8.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.1",
    "@types/node": "^22.7.7",
    "@jest/globals": "^29.7.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jsdom": "^20.0.3",
    "supertest": "^7.1.3",
    "axe-core": "^4.8.2",
    "@axe-core/puppeteer": "^4.8.2",
    "@babel/core": "^7.23.5",
    "@babel/preset-env": "^7.23.5",
    "babel-jest": "^29.7.0",
    "whatwg-fetch": "^3.6.20"
  }
}
