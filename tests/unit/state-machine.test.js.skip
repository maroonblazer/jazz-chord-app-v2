import { test, expect, describe, beforeEach, jest } from '@jest/globals';
import { JSDOM } from 'jsdom';

// Mock DOM environment
const dom = new JSDOM(`
  <!DOCTYPE html>
  <html>
    <body>
      <button id="start-stop-button">
        <span id="start-stop-button-label">Start</span>
      </button>
      <div id="session-progress">0 / 10</div>
      <div id="timer-display">00:00</div>
      <div id="results-container" style="display: none;"></div>
      <div id="fretboard-container"></div>
    </body>
  </html>
`);

global.document = dom.window.document;
global.window = dom.window;
global.performance = { now: jest.fn() };

// Mock SessionState enum
const SessionState = {
  STOPPED: 'STOPPED',
  RUNNING: 'RUNNING', 
  PAUSED: 'PAUSED',
  LAST: 'LAST',
  END: 'END'
};

// Mock session management functions
class SessionManager {
  constructor() {
    this.state = SessionState.STOPPED;
    this.currentIteration = 0;
    this.maxIterations = 10;
    this.startTime = null;
    this.totalTime = 0;
    this.sessionData = [];
  }

  setState(newState) {
    const previousState = this.state;
    this.state = newState;
    this.onStateChange(previousState, newState);
  }

  onStateChange(previousState, newState) {
    const button = document.getElementById('start-stop-button-label');
    const progress = document.getElementById('session-progress');
    
    switch (newState) {
      case SessionState.STOPPED:
        if (button) button.textContent = 'Start';
        break;
      case SessionState.RUNNING:
        if (button) button.textContent = 'Stop';
        this.startTimer();
        break;
      case SessionState.PAUSED:
        if (button) button.textContent = 'Start';
        this.stopTimer();
        break;
      case SessionState.LAST:
        if (button) button.textContent = 'Stop';
        break;
      case SessionState.END:
        if (button) button.textContent = 'See Results';
        if (progress) progress.textContent = `${this.maxIterations} / ${this.maxIterations}`;
        break;
    }
  }

  startTimer() {
    this.startTime = performance.now();
  }

  stopTimer() {
    if (this.startTime) {
      const elapsed = performance.now() - this.startTime;
      this.totalTime += elapsed;
      this.sessionData.push({
        iteration: this.currentIteration + 1,
        time: elapsed
      });
      this.currentIteration++;
      this.startTime = null;
      
      if (this.currentIteration >= this.maxIterations) {
        this.setState(SessionState.END);
      } else if (this.currentIteration === this.maxIterations - 1) {
        this.setState(SessionState.LAST);
      } else {
        this.setState(SessionState.PAUSED);
      }
    }
  }

  handleButtonClick() {
    switch (this.state) {
      case SessionState.STOPPED:
      case SessionState.PAUSED:
        this.setState(SessionState.RUNNING);
        break;
      case SessionState.RUNNING:
      case SessionState.LAST:
        this.stopTimer();
        break;
      case SessionState.END:
        this.showResults();
        break;
    }
  }

  showResults() {
    const resultsContainer = document.getElementById('results-container');
    if (resultsContainer) {
      resultsContainer.style.display = 'block';
    }
  }

  reset() {
    this.state = SessionState.STOPPED;
    this.currentIteration = 0;
    this.totalTime = 0;
    this.sessionData = [];
    this.startTime = null;
  }
}

describe('Session State Machine', () => {
  let sessionManager;

  beforeEach(() => {
    sessionManager = new SessionManager();
    // Reset DOM
    document.getElementById('start-stop-button-label').textContent = 'Start';
    document.getElementById('session-progress').textContent = '0 / 10';
    document.getElementById('results-container').style.display = 'none';
    
    // Mock performance.now with incrementing values
    let mockTime = 0;
    performance.now.mockImplementation(() => {
      return mockTime += 100; // Each call adds 100ms
    });
  });

  describe('Initial State', () => {
    test('should start in STOPPED state', () => {
      expect(sessionManager.state).toBe(SessionState.STOPPED);
      expect(sessionManager.currentIteration).toBe(0);
      expect(sessionManager.sessionData).toHaveLength(0);
    });

    test('should show Start button initially', () => {
      const button = document.getElementById('start-stop-button-label');
      expect(button.textContent).toBe('Start');
    });
  });

  describe('State Transitions', () => {
    test('should transition from STOPPED to RUNNING', () => {
      sessionManager.setState(SessionState.RUNNING);
      expect(sessionManager.state).toBe(SessionState.RUNNING);
      
      const button = document.getElementById('start-stop-button-label');
      expect(button.textContent).toBe('Stop');
    });

    test('should transition from RUNNING to PAUSED on timer stop', () => {
      sessionManager.setState(SessionState.RUNNING);
      sessionManager.stopTimer();
      
      expect(sessionManager.state).toBe(SessionState.PAUSED);
      expect(sessionManager.currentIteration).toBe(1);
      expect(sessionManager.sessionData).toHaveLength(1);
    });

    test('should transition to LAST on 9th iteration', () => {
      // Simulate 8 completed iterations
      sessionManager.currentIteration = 8;
      sessionManager.setState(SessionState.RUNNING);
      sessionManager.stopTimer();
      
      expect(sessionManager.state).toBe(SessionState.LAST);
      expect(sessionManager.currentIteration).toBe(9);
    });

    test('should transition to END on 10th iteration', () => {
      // Simulate 9 completed iterations
      sessionManager.currentIteration = 9;
      sessionManager.setState(SessionState.RUNNING);
      sessionManager.stopTimer();
      
      expect(sessionManager.state).toBe(SessionState.END);
      expect(sessionManager.currentIteration).toBe(10);
      
      const button = document.getElementById('start-stop-button-label');
      expect(button.textContent).toBe('See Results');
    });
  });

  describe('Button Click Handling', () => {
    test('should start session when clicked in STOPPED state', () => {
      sessionManager.handleButtonClick();
      expect(sessionManager.state).toBe(SessionState.RUNNING);
    });

    test('should pause session when clicked in RUNNING state', () => {
      sessionManager.setState(SessionState.RUNNING);
      sessionManager.handleButtonClick();
      expect(sessionManager.state).toBe(SessionState.PAUSED);
    });

    test('should resume session when clicked in PAUSED state', () => {
      sessionManager.setState(SessionState.PAUSED);
      sessionManager.handleButtonClick();
      expect(sessionManager.state).toBe(SessionState.RUNNING);
    });

    test('should show results when clicked in END state', () => {
      sessionManager.setState(SessionState.END);
      sessionManager.handleButtonClick();
      
      const resultsContainer = document.getElementById('results-container');
      expect(resultsContainer.style.display).toBe('block');
    });
  });

  describe('Timing System', () => {
    test('should record start time when timer starts', () => {
      sessionManager.startTimer();
      expect(sessionManager.startTime).toBeTruthy();
    });

    test('should calculate elapsed time when timer stops', () => {
      sessionManager.startTimer();
      sessionManager.stopTimer();
      
      expect(sessionManager.sessionData).toHaveLength(1);
      expect(sessionManager.sessionData[0].time).toBeGreaterThan(0);
      expect(sessionManager.totalTime).toBeGreaterThan(0);
    });

    test('should accumulate total time across iterations', () => {
      // First iteration
      sessionManager.setState(SessionState.RUNNING);
      sessionManager.stopTimer();
      const firstTotal = sessionManager.totalTime;
      
      // Second iteration
      sessionManager.setState(SessionState.RUNNING);
      sessionManager.stopTimer();
      
      expect(sessionManager.totalTime).toBeGreaterThan(firstTotal);
      expect(sessionManager.sessionData).toHaveLength(2);
    });
  });

  describe('Session Data Collection', () => {
    test('should collect timing data for each iteration', () => {
      for (let i = 0; i < 3; i++) {
        sessionManager.setState(SessionState.RUNNING);
        sessionManager.stopTimer();
      }
      
      expect(sessionManager.sessionData).toHaveLength(3);
      sessionManager.sessionData.forEach((data, index) => {
        expect(data.iteration).toBe(index + 1);
        expect(data.time).toBeGreaterThan(0);
      });
    });

    test('should reset all data when reset is called', () => {
      // Generate some data
      sessionManager.setState(SessionState.RUNNING);
      sessionManager.stopTimer();
      
      // Reset
      sessionManager.reset();
      
      expect(sessionManager.state).toBe(SessionState.STOPPED);
      expect(sessionManager.currentIteration).toBe(0);
      expect(sessionManager.totalTime).toBe(0);
      expect(sessionManager.sessionData).toHaveLength(0);
      expect(sessionManager.startTime).toBeNull();
    });
  });

  describe('Edge Cases', () => {
    test('should handle stopTimer without startTimer', () => {
      expect(() => {
        sessionManager.stopTimer();
      }).not.toThrow();
      
      expect(sessionManager.sessionData).toHaveLength(0);
    });

    test('should handle multiple startTimer calls', () => {
      sessionManager.startTimer();
      const firstStartTime = sessionManager.startTime;
      sessionManager.startTimer();
      
      // Should update start time
      expect(sessionManager.startTime).not.toBe(firstStartTime);
    });

    test('should not advance beyond max iterations', () => {
      // Set to max iterations - 1
      sessionManager.currentIteration = 9;
      sessionManager.setState(SessionState.RUNNING);
      sessionManager.stopTimer();
      
      expect(sessionManager.state).toBe(SessionState.END);
      expect(sessionManager.currentIteration).toBe(10);
      
      // Try to advance further
      sessionManager.setState(SessionState.RUNNING);
      sessionManager.stopTimer();
      
      // Should stay at END state
      expect(sessionManager.state).toBe(SessionState.END);
      expect(sessionManager.currentIteration).toBe(11); // Will increment but state stays END
    });
  });
});