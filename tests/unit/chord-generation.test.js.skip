import { test, expect, describe, beforeEach } from '@jest/globals';
import { JSDOM } from 'jsdom';

// Mock DOM environment for testing frontend code
const dom = new JSDOM(`
  <!DOCTYPE html>
  <html>
    <body>
      <div id="fretboard-container"></div>
      <div id="stringSetTextField">--</div>
      <div id="rootTextField">--</div>
      <div id="keyTextField">--</div>
      <div id="typeTextField">--</div>
      <svg id="fretboard"></svg>
    </body>
  </html>
`);

global.document = dom.window.document;
global.window = dom.window;

// Mock chord shapes data structure for testing
global.chordShapes = {
  SS1: {
    'R/1': {
      'maj7': [0, 2, 1, 1, 0, 2],
      'min7': [0, 2, 0, 1, 0, 2],
      'dom7': [0, 2, 1, 3, 0, 2]
    },
    'R/2': {
      'maj7': [2, 0, 1, 1, 2, 0],
      'min7': [2, 0, 0, 1, 2, 0]
    }
  },
  SS2: {
    'R/2': {
      'maj7': [1, 1, 1, 2, 1, 1],
      'min7': [1, 1, 0, 2, 1, 1]
    }
  }
};

global.keys = ['C', 'Db', 'D', 'Eb', 'E', 'F', 'Gb', 'G', 'Ab', 'A', 'Bb', 'B'];
global.types = ['maj7', 'maj9', 'min7', 'min9', 'dom7', 'm7b5', 'alt dom', 'dom13'];

// Import the functions we want to test (these would need to be exported from app.js)
// For now, we'll define simplified versions for testing

function getRandomStringSet() {
  return Math.random() < 0.5 ? 1 : 2;
}

function getRandomRoot(stringSet) {
  return stringSet === 1 ? Math.floor(Math.random() * 4) + 1 : Math.floor(Math.random() * 4) + 2;
}

function getRandomKey() {
  return keys[Math.floor(Math.random() * keys.length)];
}

function getRandomType() {
  return types[Math.floor(Math.random() * types.length)];
}

function isValidChordShape(stringSet, root, type) {
  const ss = `SS${stringSet}`;
  const rootKey = `R/${root}`;
  return chordShapes[ss] && chordShapes[ss][rootKey] && chordShapes[ss][rootKey][type];
}

function generateChordProblem(options = {}) {
  let stringSet, root, key, type;
  let attempts = 0;
  const maxAttempts = 100;

  do {
    stringSet = options.stringSet || getRandomStringSet();
    root = options.root || getRandomRoot(stringSet);
    key = options.key || getRandomKey();
    type = options.type || getRandomType();
    attempts++;
  } while (!isValidChordShape(stringSet, root, type) && attempts < maxAttempts);

  if (attempts >= maxAttempts) {
    throw new Error('Could not generate valid chord after maximum attempts');
  }

  return { stringSet, root, key, type };
}

describe('Chord Generation Logic', () => {
  describe('getRandomStringSet', () => {
    test('should return either 1 or 2', () => {
      for (let i = 0; i < 100; i++) {
        const result = getRandomStringSet();
        expect([1, 2]).toContain(result);
      }
    });
  });

  describe('getRandomRoot', () => {
    test('should return valid root for string set 1 (1-4)', () => {
      for (let i = 0; i < 100; i++) {
        const result = getRandomRoot(1);
        expect(result).toBeGreaterThanOrEqual(1);
        expect(result).toBeLessThanOrEqual(4);
      }
    });

    test('should return valid root for string set 2 (2-5)', () => {
      for (let i = 0; i < 100; i++) {
        const result = getRandomRoot(2);
        expect(result).toBeGreaterThanOrEqual(2);
        expect(result).toBeLessThanOrEqual(5);
      }
    });
  });

  describe('getRandomKey', () => {
    test('should return valid chromatic key', () => {
      const validKeys = ['C', 'Db', 'D', 'Eb', 'E', 'F', 'Gb', 'G', 'Ab', 'A', 'Bb', 'B'];
      for (let i = 0; i < 100; i++) {
        const result = getRandomKey();
        expect(validKeys).toContain(result);
      }
    });
  });

  describe('getRandomType', () => {
    test('should return valid chord type', () => {
      const validTypes = ['maj7', 'maj9', 'min7', 'min9', 'dom7', 'm7b5', 'alt dom', 'dom13'];
      for (let i = 0; i < 100; i++) {
        const result = getRandomType();
        expect(validTypes).toContain(result);
      }
    });
  });

  describe('isValidChordShape', () => {
    test('should return true for valid chord shapes', () => {
      expect(isValidChordShape(1, 1, 'maj7')).toBe(true);
      expect(isValidChordShape(1, 1, 'min7')).toBe(true);
      expect(isValidChordShape(2, 2, 'maj7')).toBe(true);
    });

    test('should return false for invalid chord shapes', () => {
      expect(isValidChordShape(1, 5, 'maj7')).toBe(false); // Invalid root for SS1
      expect(isValidChordShape(3, 1, 'maj7')).toBe(false); // Invalid string set
      expect(isValidChordShape(1, 1, 'invalid')).toBe(false); // Invalid type
    });
  });

  describe('generateChordProblem', () => {
    test('should generate valid chord problem without options', () => {
      const chord = generateChordProblem();
      expect([1, 2]).toContain(chord.stringSet);
      expect(chord.root).toBeGreaterThanOrEqual(chord.stringSet === 1 ? 1 : 2);
      expect(chord.root).toBeLessThanOrEqual(chord.stringSet === 1 ? 4 : 5);
      expect(keys).toContain(chord.key);
      expect(types).toContain(chord.type);
      expect(isValidChordShape(chord.stringSet, chord.root, chord.type)).toBe(true);
    });

    test('should respect provided options', () => {
      const options = { stringSet: 1, type: 'maj7' };
      const chord = generateChordProblem(options);
      expect(chord.stringSet).toBe(1);
      expect(chord.type).toBe('maj7');
      expect(isValidChordShape(chord.stringSet, chord.root, chord.type)).toBe(true);
    });

    test('should generate different chords on multiple calls', () => {
      const chords = [];
      for (let i = 0; i < 20; i++) {
        chords.push(generateChordProblem());
      }
      
      // Check that we got some variety (not all identical)
      const unique = [...new Set(chords.map(c => `${c.stringSet}-${c.root}-${c.key}-${c.type}`))];
      expect(unique.length).toBeGreaterThan(1);
    });

    test('should throw error if no valid chord can be generated', () => {
      // Mock an impossible scenario
      const originalChordShapes = global.chordShapes;
      global.chordShapes = { SS1: {}, SS2: {} };
      
      expect(() => {
        generateChordProblem();
      }).toThrow('Could not generate valid chord after maximum attempts');
      
      global.chordShapes = originalChordShapes;
    });
  });

  describe('Chord filtering and uniqueness', () => {
    test('should not repeat recent chords', () => {
      const recentChords = [
        { stringSet: 1, root: 1, key: 'C', type: 'maj7' },
        { stringSet: 1, root: 2, key: 'D', type: 'min7' }
      ];
      
      // This would require access to the chordsToForget array from app.js
      // For now, we'll test the concept
      const newChord = generateChordProblem();
      const isDifferent = !recentChords.some(recent => 
        recent.stringSet === newChord.stringSet &&
        recent.root === newChord.root &&
        recent.key === newChord.key &&
        recent.type === newChord.type
      );
      
      // This test will pass because we're generating from a larger pool
      expect(isDifferent).toBe(true);
    });
  });
});